{
	"$schema": "https://turborepo.dev/schema.json",
	"extends": ["//"],
	"tasks": {
		"fetch": {
			"dependsOn": ["^build"],
			"cache": false,
			"inputs": ["$TURBO_DEFAULT$", "!index.html", "!public/**", "!src/**", "!README.md", "scripts/fetchRepository.ts"],
			"outputLogs": "new-only"
		},
		"build": {
			"dependsOn": ["$TURBO_EXTENDS$", "fetch"],
			"inputs": ["$TURBO_EXTENDS$", "public/config/tree.json"],
			"outputLogs": "new-only"
		}
	}
}
